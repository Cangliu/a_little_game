    {"id": "pipe_select", "label": "Top-10 加权抽取\n→ EventDirector", "semantic": "decision", "layer": 1, "width": 180},

    {"id": "ed_prompt", "label": "🤖 Prompt组装\n近期经历+相关记忆+候选+Saga上下文", "semantic": "ai", "layer": 1, "width": 300},
    {"id": "ed_output", "label": "LLM输出 (SSE流式)\n选事件+叙事200-300字+可选分支+因果链", "semantic": "ai", "layer": 1, "width": 320},

    {"id": "npc_sys", "label": "👥 NPC系统\n生成(MAX 30) → 关系图谱(好感±∆) → 命运线(多阶段PIVOT) → 专属事件", "semantic": "trigger", "layer": 2, "width": 460},
    {"id": "mem_sys", "label": "🧠 记忆系统\nWorking(5条全量) → Short-term(overflow) → Long-term(LLM压缩传记)", "semantic": "storage", "layer": 2, "width": 420},
    {"id": "mem_retriever", "label": "🔍 混合检索\nBM25 bigram(0.4) + m3e-base Embedding(0.6) + 时间衰减 → Top-3注入", "semantic": "ai", "layer": 2, "width": 440},
    {"id": "hook_sys", "label": "🔗 因果系统 (CausalityEngine)\n伏笔种植(creates_hook) → 回收(resolves_hook) → 权重×2 → 到期强制 → LLM因果链", "semantic": "ai", "layer": 2, "width": 480},
    {"id": "saga_sys", "label": "📖 Saga弧线\n检测(NPC/关键词交集) → 张力曲线(momentum 0-100) → 方向暗示注入Arc", "semantic": "core", "layer": 2, "width": 420},
    {"id": "arc_sys", "label": "🎯 StoryArc + MainStoryline\nLLM规划(突破触发) → 4阶段推进 → 关键词×3 boost + 命运骨骼", "semantic": "core", "layer": 2, "width": 460},
    {"id": "era_sys", "label": "🌍 天地纪元 (WorldEra)\n18纪元池 | 80-180年触发 | category_boost×2.0 + tension_mod", "semantic": "external", "layer": 2, "width": 400},
    {"id": "realm_sys", "label": "⭐ 境界系统\n觉醒(凡人→练气) → 修为增长(base×mod×years) → 突破判定(概率+门槛) → 80%预兆", "semantic": "trigger", "layer": 2, "width": 460},
    {"id": "sect_sys", "label": "🏯 宗门系统\n动态生成 → 三维晋升(贡献+声望+境界) → 政治斗争 → 危机/开除/散修招募", "semantic": "trigger", "layer": 2, "width": 460},

    {"id": "llm_flash", "label": "DeepSeek Flash | T=0.75 | 前缀缓存 | 默认模型", "semantic": "ai", "layer": 3, "width": 340},
    {"id": "llm_pro", "label": "DeepSeek Pro | 张力≥70 | Saga≥60 | 境界突破 | 纪元变更", "semantic": "ai", "layer": 3, "width": 380},
    {"id": "llm_emb", "label": "m3e-base | 本地Embedding | 零API成本", "semantic": "storage", "layer": 3, "width": 280},
    {"id": "state", "label": "GameState | 主角全量状态快照 | 纯内存运行", "semantic": "storage", "layer": 3, "shape": "cylinder", "width": 320}
