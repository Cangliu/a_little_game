    {"id": "mem_sys", "label": "🧠 记忆系统\nWorking(5条全量) → Short-term(overflow) → Long-term(LLM压缩传记)", "semantic": "storage", "layer": 2, "width": 420},
    {"id": "mem_retriever", "label": "🔍 混合检索\nBM25 bigram(0.4) + m3e-base Embedding(0.6) → Top-3注入Prompt", "semantic": "ai", "layer": 2, "width": 420},
    {"id": "hook_sys", "label": "🔗 因果系统 (PlotHooks)\n伏笔种植(creates_hook) → 回收(resolves_hook) → 权重×2 → 到期强制 → LLM因果链", "semantic": "ai", "layer": 2, "width": 460},
    {"id": "saga_sys", "label": "📖 Saga弧线\n检测(NPC/关键词交集) → 张力曲线(momentum 0-100) → 方向暗示注入Arc", "semantic": "core", "layer": 2, "width": 420},
    {"id": "arc_sys", "label": "🎯 StoryArc\nLLM规划(突破触发) → 4阶段(setup→rising→climax→end) → 关键词×3 boost事件权重", "semantic": "core", "layer": 2, "width": 460},
    {"id": "era_sys", "label": "🌍 天地纪元\n~20纪元池 | 80-180年触发 | category_boost + tension_mod", "semantic": "external", "layer": 2, "width": 380},
    {"id": "realm_sys", "label": "⭐ 境界系统\n觉醒(凡人→练气) → 修为增长(base×mod×years) → 突破判定(概率+门槛) → 80%预兆", "semantic": "trigger", "layer": 2, "width": 460},

    {"id": "llm_flash", "label": "DeepSeek Flash | T=0.75 | 前缀缓存 | 默认模型", "semantic": "ai", "layer": 3, "width": 340},
    {"id": "llm_pro", "label": "DeepSeek Pro | 张力≥70 | Saga≥60 | 弧线高潮", "semantic": "ai", "layer": 3, "width": 340},
    {"id": "llm_emb", "label": "m3e-base | 本地Embedding | 零API成本", "semantic": "storage", "layer": 3, "width": 280},
    {"id": "state", "label": "GameState | 主角全量状态快照 | 纯内存", "semantic": "storage", "layer": 3, "shape": "cylinder", "width": 300}
